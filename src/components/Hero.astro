---

<section id="hero" class="hero-section">
    <div class="hero-container">
        <div class="hero-text">
            <h1>Hola, soy <span class="name-highlight">Bruno Gamberini</span></h1>
            <h2><span class="role-highlight">Desarrollador Web</span> en Argentina.</h2>
        </div>
        <div class="hero-badge">
            <div class="badge-icon">💻</div>
            <span>Disponible para proyectos</span>
        </div>
    </div>
    <a href="#experience" class="hero-arrow" aria-label="Bajar a experiencia">
        <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 28L8 14H28L18 28Z" fill="var(--accent-cyan)"/>
        </svg>
    </a>
</section>

<style>
.hero-section {
    height: calc(100vh - 73px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 900px;
    width: 100%;
    padding: 0 20px;
    text-align: center;
}

.hero-text {
    margin-bottom: 30px;
}

.name-highlight {
    color: var(--accent-cyan);
    text-shadow: 0 0 20px rgba(0, 210, 255, 0.4);
    position: relative;
}

.name-highlight::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent);
    animation: shimmer 2s ease-in-out infinite;
}

@keyframes shimmer {
    0%, 100% { opacity: 0.5; transform: scaleX(0.8); }
    50% { opacity: 1; transform: scaleX(1); }
}

.role-highlight {
    text-decoration: 3px wavy underline var(--accent-cyan);
    text-underline-offset: 6px;
    text-shadow: 0 0 15px rgba(0, 210, 255, 0.2);
    position: relative;
    background: linear-gradient(45deg, var(--accent-cyan), var(--accent-cyan-hover));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: glow 3s ease-in-out infinite alternate;
}

.hero-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: var(--accent-cyan-alpha);
    border: 2px solid var(--border-color);
    border-radius: 50px;
    backdrop-filter: blur(10px);
    transition: var(--transition);
    animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 210, 255, 0.3); }
    50% { transform: scale(1.02); box-shadow: 0 0 0 10px rgba(0, 210, 255, 0); }
}

.badge-icon {
    font-size: 20px;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
}

.hero-badge span {
    color: var(--accent-cyan);
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

h1 {
    display: flex;
    align-items: center;
    margin: 0 0 32px 0;
    font-size: 48px;
    gap: 12px;
    max-width: 900px;
    color: var(--text-primary);
}

h2 {
    line-height: 1;
    font-size: 30px;
    margin-top: 0px;
    color: var(--text-primary);
}

p {
    width: 100%;
}

.hero-arrow {
    position: absolute;
    left: 50%;
    bottom: 36px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    animation: bounce 1.5s infinite;
    z-index: 10;
    transition: opacity 120ms cubic-bezier(0.2,0.8,0.2,1);
    will-change: opacity, transform;
}

.hero-arrow svg {
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.18));
    transition: var(--transition);
}

.hero-arrow:hover svg {
    transform: scale(1.15);
    filter: drop-shadow(0 2px 8px rgba(0, 210, 255, 0.6));
}

@keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
}

@media (max-width: 768px) {
    .hero-section {
        height: calc(85vh - 89px);
        margin-bottom: 100px;
    }

    h1 {
        font-size: 40px; 
        flex-direction: column; 
        gap: 8px;
    }

    h2 {
        font-size: 20px;
        line-height: 1.3;
    }

    .hero-badge {
        gap: 8px;
        border: 1px solid var(--accent-cyan);
        padding: 8px 16px;
    }

    .hero-badge span {
        font-size: 12px; 
    }

    .hero-arrow {
        bottom: 30px; 
    }

    .hero-arrow svg {
        width: 30px;
        height: 30px;
    }

    @keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(15px); }
    }
}

@media (max-width: 380px) {
    h1 {
        font-size: 28px;
    }
    
    h2 {
        font-size: 18px;
    }
}
</style>

<script type="module">
    (function () {
        const arrow = document.querySelector('.hero-arrow');
        const hero = document.getElementById('hero');
        if (!arrow || !hero) return;

        const FADE_START = 0.8;
        const EASE_POWER = 1.4;

        function applyOpacity(ratio) {
            const normalized = (ratio - FADE_START) / (1 - FADE_START);
            const clamped = Math.max(0, Math.min(1, normalized));
            const o = Math.pow(clamped, EASE_POWER);
            arrow.style.opacity = String(o);
            arrow.style.pointerEvents = o < 0.05 ? 'none' : 'auto';
            arrow.style.animationPlayState = o < 0.12 ? 'paused' : 'running';
        }

        function buildThresholdList() {
            const thresholds = [];
            for (let i = 0; i <= 100; i++) thresholds.push(i / 100);
            return thresholds;
        }

        if ('IntersectionObserver' in window) {
            const io = new IntersectionObserver((entries) => {
                entries.forEach(entry => applyOpacity(entry.intersectionRatio || 0));
            }, { threshold: buildThresholdList() });
            io.observe(hero);
        } else {
            let heroH = hero.offsetHeight || window.innerHeight;
            function update() {
                const rect = hero.getBoundingClientRect();
                const visible = Math.max(0, Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0));
                const ratio = visible / heroH;
                applyOpacity(ratio);
            }
            let ticking = false;
            window.addEventListener('scroll', () => {
                if (!ticking) {
                    requestAnimationFrame(() => { update(); ticking = false; });
                    ticking = true;
                }
            }, { passive: true });
            window.addEventListener('resize', () => { heroH = hero.offsetHeight || window.innerHeight; update(); });
            update();
        }
    })();
</script>