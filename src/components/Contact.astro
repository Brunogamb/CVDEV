---
---

<section id="contact" class="contact-section">
    <h2><i class="fa-solid fa-envelope"></i>Contacto</h2>
    
    <div class="contact-container">
        <div class="contact-info">
            <h3>¡Trabajemos juntos!</h3>
            <p>¿Tenes un proyecto en mente? Me encantaría escuchar sobre él. Completa el formulario y <span>te responderé lo antes posible</span>.</p>
            
            <div class="contact-details">
                <div class="detail-item">
                    <i class="fa-solid fa-clock"></i>
                    <div>
                        <h4>Disponibilidad</h4>
                        <p>Lun a Vie · 14:00 - 20:00</p>
                        <p>Respuesta en 24-48 horas</p>
                    </div>
                </div>
            </div>
        </div>

        <form class="contact-form" id="contact-form" action="https://formspree.io/f/xqewbdar" method="POST">
            <div class="form-group">
                <label for="name">Nombre completo</label>
                <input type="text" id="name" name="name" placeholder="Bruno Gamberini" required>
            </div>
            
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="brunogamberini24@gmail.com" required>
            </div>
            
            <div class="form-group">
                <label for="message">Mensaje</label>
                <textarea id="message" name="message" rows="5" placeholder="Cuéntame sobre tu proyecto..." required></textarea>
            </div>
            
            <button type="submit" class="submit-btn">
                <i class="fa-solid fa-paper-plane"></i>
                Enviar mensaje
            </button>
            
            <div id="form-status" class="form-status"></div>
        </form>
    </div>
</section>

<style>
.contact-section {
    min-height: 80vh; 
    height: auto;     
    padding: 10px 0 0 0;   
}

.contact-container {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    max-width: 900px;
    width: 100%;
    margin: auto;
    padding: 0 20px;
    gap: 40px;
}

.contact-info h3 {
    font-size: 22px;
    color: var(--accent-cyan);
    margin: 0 0 18px 0;
    line-height: 1.2;
    font-weight: 700;
}

.contact-info p {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 36px;
    line-height: 1.6;
    width: 100%;
}

.contact-info {
    flex: 1;
    max-width: 400px;
}

.contact-info span {
    color: var(--accent-cyan);
}

.detail-item {
    display: flex;
    gap: 18px;
    align-items: flex-start;
}

.detail-item i {
    font-size: 22px;
    color: var(--accent-cyan);
    margin-top: 2px;
    min-width: 22px;
    padding: 8px;
    background: var(--accent-cyan-alpha);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.detail-item h4 {
    font-size: 16px;
    color: var(--accent-cyan);
    margin: 0 0 10px 0;
    line-height: 1;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.detail-item p {
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0 0 6px 0;
    line-height: 1.4;
}

.contact-form {
    background: var(--card-bg);
    border: 2px solid var(--border-color);
    border-radius: 12px;
    padding: 32px;
    width: 100%;
    max-width: 500px;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.form-group {
    margin-bottom: 24px;
}

.form-group label {
    display: block;
    font-size: 14px;
    color: var(--accent-cyan);
    margin-bottom: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: var(--text-primary);
    font-size: 16px;
    transition: var(--transition);
    font-family: inherit;
    backdrop-filter: blur(5px);
    box-sizing: border-box;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--accent-cyan);
    background: var(--accent-cyan-alpha);
    box-shadow: 0 0 0 4px var(--accent-cyan-alpha);
    transform: translateY(-1px);
}

.form-group textarea {
    resize: none;
    scroll-behavior: smooth;
    scrollbar-color: var(--accent-cyan) var(--bg-dark);
}

.form-group input::placeholder,
.form-group textarea::placeholder {
    color: #888;
}

.submit-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #1a1a1a;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 28px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--accent-cyan-hover) 100%);
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
    width: 100%;
    justify-content: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0, 210, 255, 0.3);
}

.submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
    box-shadow: 0 4px 15px rgba(0, 210, 255, 0.2);
}

.form-status {
    margin-top: 16px;
    padding: 12px;
    border-radius: 8px;
    text-align: center;
    font-weight: 500;
    display: none;
}

.form-status.success {
    background: rgba(34, 197, 94, 0.1);
    border: 2px solid #22c55e;
    color: #22c55e;
    display: block;
}

.form-status.error {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid #ef4444;
    color: #ef4444;
    display: block;
}

h2 {
    display: flex;
    align-items: center;
    margin: 40px auto 32px auto;
    font-size: 32px;
    gap: 12px;
    max-width: 900px;
    padding: 0 20px;
    color: var(--text-primary);
}

h3, h4 {
    line-height: 1;
}

h3 {
    font-size: 20px;
    color: var(--accent-cyan);
}

h4 {
    font-size: 16px;
}

p {
    width: 100%;
}

@media (hover: hover) {   
    .submit-btn:hover {
        background: linear-gradient(135deg, var(--accent-cyan-hover) 0%, var(--accent-cyan) 100%);
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 210, 255, 0.4);
    }
}

@media (max-width: 768px) {
    .contact-container {
        flex-direction: column;
        gap: 20px;
        align-items: center;
    }
    
    .contact-form {
        padding: 24px 20px;
        width: 100%;
    }
    
    .contact-info {
        width: 100%;
        text-align: center;
    }
    
    .detail-item {
        display: none;
    }

    .contact-section {
        height: auto; 
        padding: 40px 0 80px 0; 
    }

    .contact-info p {
        text-wrap: balance;
    }

    .form-group label {
        font-size: 12px; 
    }

    .form-group input, 
    .form-group textarea {
        font-size: 16px;
        padding: 12px 15px;
    }

    h2 {
        font-size: 26px;
        justify-content: center;
    }
}
</style>

<script type="module">
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    const submitBtn = form.querySelector('.submit-btn');
    
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Enviando...';
        
        status.style.display = 'none';
        status.className = 'form-status';
        
        const formData = new FormData(form);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'Accept': 'application/json'
                }
            });

            if (response.ok) {
                status.className = 'form-status success';
                status.textContent = '¡Mensaje enviado correctamente! Te responderé pronto.';
                status.style.display = 'block';
                form.reset();
            } else {
                const data = await response.json();
                throw new Error(data.error || 'Error al enviar');
            }
            
        } catch (error) {
            status.className = 'form-status error';
            status.textContent = 'Hubo un error al enviar el mensaje. Por favor, intenta nuevamente.';
            status.style.display = 'block';
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Enviar mensaje';
        }
    });
});
</script>